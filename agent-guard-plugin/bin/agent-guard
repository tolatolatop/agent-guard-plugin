#!/usr/bin/env node

const path = require("node:path");
const {
  AGENT_DIR,
  loadState,
  saveState,
  ensureAgentFiles,
  updateState,
} = require("../lib/state");
const { decideWrite } = require("../lib/path-policy");
const {
  recordCommandResult,
  checkFailureLoop,
} = require("../lib/failures");
const { canFinalize } = require("../lib/gates");
const { getSessionReminder, getNextStep } = require("../lib/runtime-adapter");
const { loadJobs, checkJobPoll } = require("../lib/jobs");
const { loadPlanSummary } = require("../lib/plan");
const { installRuntime } = require("../lib/install");

function printJson(data, exitCode = 0) {
  process.stdout.write(`${JSON.stringify(data, null, 2)}\n`);
  process.exit(exitCode);
}

function parseArgs(argv) {
  const [command, ...rest] = argv;
  return { command, rest };
}

function parseFlags(args) {
  const flags = {};
  for (let index = 0; index < args.length; index += 1) {
    const current = args[index];
    if (!current.startsWith("--")) {
      continue;
    }

    const key = current.slice(2);
    const next = args[index + 1];
    if (!next || next.startsWith("--")) {
      flags[key] = true;
      continue;
    }

    flags[key] = next;
    index += 1;
  }
  return flags;
}

function ensurePathArg(rest, name) {
  const value = rest[0];
  if (!value) {
    printJson({ error: `Missing required argument: ${name}` }, 1);
  }
  return value;
}

function run() {
  const cwd = process.cwd();
  const { command, rest } = parseArgs(process.argv.slice(2));

  try {
    switch (command) {
      case "init": {
        ensureAgentFiles(cwd);
        printJson({
          ok: true,
          agent_dir: path.join(cwd, AGENT_DIR),
        });
        break;
      }
      case "start-task": {
        const taskId = ensurePathArg(rest, "task-id");
        ensureAgentFiles(cwd);
        const state = updateState(cwd, (current) => ({
          ...current,
          task_id: taskId,
          stage: current.stage === "IDLE" ? "CLARIFYING" : current.stage,
        }));
        printJson({ ok: true, state });
        break;
      }
      case "status": {
        const state = loadState(cwd);
        const jobs = loadJobs(cwd);
        const plan = loadPlanSummary(cwd);
        printJson({
          ok: true,
          state,
          jobs,
          plan,
          next_step: getNextStep(state),
        });
        break;
      }
      case "session-start": {
        const reminder = getSessionReminder(cwd);
        printJson({ ok: true, ...reminder });
        break;
      }
      case "can-write": {
        const targetPath = ensurePathArg(rest, "path");
        const decision = decideWrite(loadState(cwd), targetPath);
        printJson(decision, decision.decision === "allow" ? 0 : 1);
        break;
      }
      case "record-command": {
        const flags = parseFlags(rest);
        if (!flags.cmd || flags["exit-code"] === undefined || !flags.log) {
          printJson(
            {
              error:
                "Usage: agent-guard record-command --cmd \"<command>\" --exit-code <code> --log <path>",
            },
            1,
          );
        }

        const result = recordCommandResult(cwd, {
          command: flags.cmd,
          exitCode: Number(flags["exit-code"]),
          logPath: flags.log,
        });
        printJson({ ok: true, ...result });
        break;
      }
      case "check-failure-loop": {
        const result = checkFailureLoop(cwd);
        printJson(result, result.decision === "allow" ? 0 : 1);
        break;
      }
      case "check-job-poll": {
        const jobId = ensurePathArg(rest, "job-id");
        const result = checkJobPoll(cwd, jobId);
        printJson(result, result.decision === "allow" ? 0 : 1);
        break;
      }
      case "can-finalize": {
        const result = canFinalize(cwd);
        printJson(result, result.decision === "allow" ? 0 : 1);
        break;
      }
      case "next-step": {
        const state = loadState(cwd);
        printJson({ ok: true, next_step: getNextStep(state) });
        break;
      }
      case "install": {
        const result = installRuntime(rest, {
          cwd,
          homeDir: process.env.HOME,
          pluginRoot: path.resolve(__dirname, ".."),
        });
        printJson({ ok: true, ...result });
        break;
      }
      default:
        printJson(
          {
            error:
              "Unknown command. Supported: init, start-task, status, session-start, can-write, record-command, check-failure-loop, check-job-poll, can-finalize, next-step, install",
          },
          1,
        );
    }
  } catch (error) {
    printJson(
      {
        error: error.message,
      },
      1,
    );
  }
}

run();
